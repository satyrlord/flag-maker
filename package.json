{
  "name": "flag-maker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "serve": "vite build && vite preview",
    "lint": "eslint src/",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"!node_modules\" \"!test-results\"",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.tools.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:coverage": "cross-env E2E_COVERAGE=true playwright test",
    "build:symbols": "tsx tools/build-symbol-catalog.ts",
    "prune:runtime-symbols": "tsx tools/prune-runtime-symbols.ts",
    "build:template-previews": "tsx tools/build-template-previews.ts",
    "quality": "npm run typecheck && npm run lint && npm run lint:md && npm run test:coverage",
    "quality:full": "npm run quality && npm run test:e2e:coverage",
    "fetch-emblems": "tsx tools/fetch-emblems.ts",
    "fetch-symbols": "tsx tools/fetch-symbols.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.1.0",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^25.3.5",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.20",
    "cross-env": "^10.1.0",
    "daisyui": "^5.5.19",
    "eslint": "^10.0.3",
    "fast-xml-parser": "^5.2.5",
    "jsdom": "^28.1.0",
    "markdownlint-cli2": "^0.21.0",
    "monocart-coverage-reports": "^2.12.9",
    "postcss": "^8.4.44",
    "svgo": "^4.0.1",
    "tailwindcss": "^4.1.12",
    "tsx": "^4.21.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.1.3",
    "vite-plugin-istanbul": "^7.2.1",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  }
}
